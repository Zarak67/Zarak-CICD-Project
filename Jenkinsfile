pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                echo 'Checking code from GitHub'
            }
        }

        stage('Build') {
            steps {
                echo 'Building Zarak CICD Project'
            }
        }

        stage('Test') {
            steps {
                echo 'Running tests'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploy stage completed'
            }
        }
    }
}
